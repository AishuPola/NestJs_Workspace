NODE_ENV=development
PORT=3000

JWT_SECRET=your-secret-here-minimum-32-characters
JWT_EXPIRES_IN=1d

DB_HOST=localhost
DB_PORT=5432
DB_NAME=iop_dev
DB_USER=postgres
DB_PASSWORD=

APP_NAME=iop-api
APP_VERSION=1.0.0

# RabbitMQ 
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Feature flags 
# Set to true to enable Pub/Sub via RabbitMQ
ENABLE_PUBSUB=true
# Set to true to enable BullMQ background jobs
ENABLE_BULLMQ=true